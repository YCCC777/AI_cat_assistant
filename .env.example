# LINE API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Google Calendar
GOOGLE_CALENDAR_ID=your_google_calendar_id
# Google 憑證路徑 (service_account.json)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Notion API
NOTION_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_notion_database_id
NOTION_USER_PROGRESS_DB_ID=your_user_progress_db_id
NOTION_LEARNING_CARD_DB_ID=your_learning_card_db_id

# 管理員與安全
ADMIN_LINE_USER_ID=your_admin_line_user_id
DAILY_TOKEN_LIMIT=50000
# 指令與權限
ADMIN_TRANSFER_PASSWORD=your_transfer_password

# 系統設定
ENV=production # development or production
PORT=8000
